# name: test/sql/datadog.test
# description: test the datadog extension (offline: load, secret, registration, error paths)
# group: [sql]

# Before the extension is loaded the table function does not exist.
statement error
SELECT * FROM read_datadog_logs(query => '*', "from" => 'now-15m', "to" => 'now');
----
does not exist

require datadog

# The reader is registered.
query I
SELECT count(*) >= 1 FROM duckdb_functions() WHERE function_name = 'read_datadog_logs';
----
true

# Calling it without any datadog secret gives a helpful error (this only binds; no network call).
statement error
SELECT * FROM read_datadog_logs(query => '*', "from" => 'now-15m', "to" => 'now');
----
No 'datadog' secret found

# Catalog attachment validates credentials before doing anything else. Explicit INDEXES keeps
# this path offline while preserving the same helpful missing-secret error.
statement error
ATTACH 'datadog:' AS dd_missing (TYPE datadog, INDEXES ['main']);
----
No 'datadog' secret found

# The custom secret type works.
statement ok
CREATE SECRET dd_test (
    TYPE datadog,
    API_KEY 'SECRET_API_KEY_VALUE',
    APP_KEY 'SECRET_APP_KEY_VALUE',
    SITE 'datadoghq.eu'
);

query I
SELECT type FROM duckdb_secrets() WHERE name = 'dd_test';
----
datadog

# API/APP keys are redacted, never shown in duckdb_secrets().
query I
SELECT secret_string NOT LIKE '%SECRET_API_KEY_VALUE%' AND secret_string NOT LIKE '%SECRET_APP_KEY_VALUE%'
FROM duckdb_secrets() WHERE name = 'dd_test';
----
true

# With a secret present, binding succeeds and exposes the OTLP-conformant schema (bind only, no
# network call is made until the scan runs).
query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM read_datadog_logs(query => '*', "from" => 'now-15m', "to" => 'now'));
----
18

# Key OTLP columns are present (order-independent).
query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM read_datadog_logs(query => '*', "from" => 'now-15m', "to" => 'now'))
WHERE column_name IN ('time_unix_nano', 'observed_time_unix_nano', 'trace_id', 'span_id', 'severity_number',
                      'severity_text', 'body', 'resource_attributes', 'log_attributes', 'flags');
----
10

# Named parameters are validated at bind time (no network call is needed to hit these errors).
statement error
SELECT * FROM read_datadog_logs(page_size => 0);
----
page_size must be between 1 and 1000

statement error
SELECT * FROM read_datadog_logs(page_size => 1001);
----
page_size must be between 1 and 1000

statement error
SELECT * FROM read_datadog_logs(max_rows => -1);
----
max_rows must be >= 0

statement error
SELECT * FROM read_datadog_logs(retries => -1);
----
retries must be >= 0

statement error
SELECT * FROM read_datadog_logs(timeout => 0);
----
timeout must be >= 1

# The old page-size parameter name is gone (renamed to page_size before any release).
statement error
SELECT * FROM read_datadog_logs("limit" => 10);
----
Invalid named parameter

# Explicit indexes bypass network discovery entirely. Duplicate names are removed in input order.
statement ok
ATTACH 'datadog:' AS dd (
    TYPE datadog,
    SECRET 'dd_test',
    INDEXES ['main', 'security-events', 'main']
);

query I
SELECT count(*) FROM duckdb_schemas() WHERE database_name = 'dd' AND schema_name = 'logs';
----
1

query I
SELECT count(*) FROM duckdb_tables() WHERE database_name = 'dd' AND schema_name = 'logs';
----
2

query I
SELECT count(*) FROM duckdb_tables()
WHERE database_name = 'dd' AND schema_name = 'logs' AND table_name = 'main';
----
1

query I rowsort
SELECT table_name FROM duckdb_tables() WHERE database_name = 'dd' AND schema_name = 'logs';
----
main
security-events

# Catalog tables and the stable table function expose exactly the same 18 columns and types.
query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM dd.logs.main);
----
18

query I
SELECT count(*)
FROM (
    (SELECT column_name, column_type FROM (DESCRIBE SELECT * FROM dd.logs.main))
    EXCEPT ALL
    (SELECT column_name, column_type FROM (DESCRIBE SELECT * FROM read_datadog_logs()))
);
----
0

# Datadog index names are preserved and names requiring quoting bind normally.
query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM dd.logs."security-events");
----
18

# Explicit names must be non-null and non-empty.
statement error
ATTACH 'datadog:' AS dd_null (TYPE datadog, SECRET 'dd_test', INDEXES ['main', NULL]);
----
INDEXES must contain only non-null VARCHAR names

statement error
ATTACH 'datadog:' AS dd_empty (TYPE datadog, SECRET 'dd_test', INDEXES ['']);
----
INDEXES must not contain empty index names

# Unknown storage options fail at attach time with a useful allow-list.
statement error
ATTACH 'datadog:' AS dd_bad_option (TYPE datadog, SECRET 'dd_test', INDEXES ['main'], FOO 'bar');
----
Unsupported Datadog ATTACH option 'foo'

# The attached catalog is genuinely read-only across DDL and DML paths.
statement error
CREATE TABLE dd.logs.nope(i INTEGER);
----
read-only

statement error
DROP TABLE dd.logs.main;
----
read-only

statement error
ALTER TABLE dd.logs.main RENAME TO renamed;
----
read-only

statement error
INSERT INTO dd.logs.main (body) VALUES ('not allowed');
----
read-only

statement error
UPDATE dd.logs.main SET body = 'not allowed';
----
read-only

statement error
DELETE FROM dd.logs.main;
----
read-only

statement ok
DETACH dd;

query I
SELECT count(*) FROM duckdb_tables() WHERE database_name = 'dd';
----
0

# Omitting SECRET uses the same first in-scope Datadog secret selection as the table function.
statement ok
ATTACH 'datadog:' AS dd_default (TYPE datadog, INDEXES ['main']);

query I
SELECT count(*) FROM duckdb_tables() WHERE database_name = 'dd_default' AND table_name = 'main';
----
1

statement ok
DETACH dd_default;
